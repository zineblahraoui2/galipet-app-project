PORT=3001
MONGO_URL=mongodb://127.0.0.1:27017/galipet
WEB_APP_URL=http://localhost:5173

# Required for POST /login (JWT + httpOnly cookie). Use a long random string in production.
JWT_SECRET=
# Optional, e.g. 7d, 24h
# JWT_EXPIRES_IN=7d

# Set to 1 while debugging POST /register multipart (logs body, file, content-type). Remove or unset after verifying.
# GALIPET_DEBUG_REGISTER=1

# Mapbox Geocoding (server-side pro registration). Same token as frontend Mapbox is fine.
# MAPBOX_TOKEN=
